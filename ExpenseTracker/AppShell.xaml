<?xml version="1.0" encoding="UTF-8" ?>
<Shell
    x:Class="ExpenseTracker.AppShell"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:local="clr-namespace:ExpenseTracker.Views"
    Title="ExpenseTracker">

    <TabBar>
        <ShellContent
            Title="Dashboard"
            ContentTemplate="{DataTemplate local:DashboardPage}"
            Route="DashboardPage" />
        <ShellContent
            Title="New"
            ContentTemplate="{DataTemplate local:NewTransactionsPage}"
            Route="NewTransactionsPage" />
        <ShellContent
            Title="History"
            ContentTemplate="{DataTemplate local:ExpenseHistoryPage}"
            Route="ExpenseHistoryPage" />
        <ShellContent
            Title="Add"
            ContentTemplate="{DataTemplate local:AddExpensePage}"
            Route="AddExpensePage" />
        <ShellContent
            Title="Reports"
            ContentTemplate="{DataTemplate local:ReportsPage}"
            Route="ReportsPage" />
        <ShellContent
            Title="Settings"
            ContentTemplate="{DataTemplate local:SettingsPage}"
            Route="SettingsPage" />
    </TabBar>

</Shell>
