<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:ExpenseTracker.ViewModels"
             xmlns:models="clr-namespace:ExpenseTracker.Models"
             x:Class="ExpenseTracker.Views.NewTransactionsPage"
             x:Name="NewTransactionsPageRoot"
             x:DataType="vm:NewTransactionsViewModel"
             Title="New Transactions">

    <!-- Changed to a Grid with defined rows to control screen height allocation -->
    <Grid RowDefinitions="Auto,Auto,Auto,*" 
          Padding="20" 
          RowSpacing="16">

        <Label Grid.Row="0" 
               Text="New Transactions" 
               FontSize="Large" 
               FontAttributes="Bold" />

        <Label Grid.Row="1" 
               Text="{Binding StatusMessage}" 
               TextColor="Red" 
               IsVisible="{Binding StatusMessage, Converter={StaticResource StringNotNullOrEmptyConverter}}" />

        <Button Grid.Row="2" 
                Text="Refresh" 
                Command="{Binding LoadNewTransactionsCommand}" />

        <!-- Placed in Row 3 (the star row) which manages constraints and enables scrolling -->
        <CollectionView Grid.Row="3" 
                        ItemsSource="{Binding ImportedTransactions}" 
                        SelectionMode="None">
            <CollectionView.ItemTemplate>
                <DataTemplate x:DataType="models:ImportedTransaction">
                    <!-- Migrated from obsolete Frame to .NET 9 Border component -->
                    <Border Background="Green" 
                            StrokeShape="RoundRectangle 10" 
                            StrokeThickness="0" 
                            Padding="12" 
                            Margin="0,0,0,10">

                        <VerticalStackLayout Spacing="8">
                            <Label Text="{Binding Merchant}" FontAttributes="Bold" />
                            <Label Text="{Binding Amount, StringFormat='₹{0:F2}'}" />
                            <Label Text="{Binding SuggestedCategory, StringFormat='Suggested: {0}'}" />

                            <!-- ✅ NEW: Date Field -->
                            <Label Text="{Binding Date, StringFormat='Date: {0:dd MMM yyyy}'}" 
           FontSize="12" 
           TextColor="LightYellow" />

                            <Label Text="{Binding TransactionType}" FontSize="Small" TextColor="AliceBlue" />
                            <Label Text="{Binding ReferenceNumber}" FontSize="Small" TextColor="AliceBlue" />
                            <Label Text="{Binding SmsContent}" LineBreakMode="TailTruncation" MaxLines="2" />

                            <Button Text="View Full Message" 
        FontSize="10"
        HeightRequest="30"
        Command="{Binding Source={RelativeSource AncestorType={x:Type vm:NewTransactionsViewModel}}, Path=ViewFullMessageCommand}" 
        CommandParameter="{Binding .}"
        Background="Transparent"  
        TextColor="Yellow" />

                            <!-- Added x:DataType="{x:Null}" to break strict type safety limitations for parent element lookup -->
                            <HorizontalStackLayout Spacing="12" x:DataType="{x:Null}">

                                <Button Text="Edit" 
                                        Command="{Binding BindingContext.EditTransactionCommand, Source={RelativeSource AncestorType={x:Type ContentPage}}}" 
                                        CommandParameter="{Binding .}" 
                                        BackgroundColor="{StaticResource Primary}" 
                                        TextColor="White" />

                                <Button Text="Accept" 
                                        Command="{Binding BindingContext.AcceptTransactionCommand, Source={RelativeSource AncestorType={x:Type ContentPage}}}" 
                                        CommandParameter="{Binding .}" 
                                        BackgroundColor="{StaticResource SecondaryDarkText}" 
                                        TextColor="White" />

                                <Button Text="Ignore" 
                                        Command="{Binding BindingContext.IgnoreTransactionCommand, Source={RelativeSource AncestorType={x:Type ContentPage}}}" 
                                        CommandParameter="{Binding .}" 
                                        BackgroundColor="LightGray" 
                                        TextColor="Black" />

                            </HorizontalStackLayout>
                        </VerticalStackLayout>
                    </Border>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>
    </Grid>
</ContentPage>