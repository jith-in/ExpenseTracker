<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:ExpenseTracker.ViewModels"
             x:Class="ExpenseTracker.Views.SettingsPage"
             x:DataType="vm:SettingsViewModel"
             Title="Settings">

    <ScrollView>
        <VerticalStackLayout Padding="20" Spacing="20">
            <Label Text="Settings" FontSize="Large" FontAttributes="Bold" />
            <Button Text="Export Expenses to CSV" Command="{Binding ExportCsvCommand}" />
            <Button Text="Create Backup" Command="{Binding CreateBackupCommand}" />
            <Button Text="Restore Backup" Command="{Binding RestoreBackupCommand}" />

            <!-- Status Message -->
            <Label Text="{Binding StatusMessage}" 
                   TextColor="Green" 
                   IsVisible="{Binding StatusMessage, Converter={StaticResource StringNotNullOrEmptyConverter}}"
                   FontAttributes="Bold" />

            <!-- Data Management Section -->
            <!-- Configured to use Border container with Dynamic Card Context color parameters -->
            <Border Background="{DynamicResource CardBackground}" 
                    StrokeShape="RoundRectangle 12" 
                    StrokeThickness="0" 
                    Padding="16" 
                    Margin="0">
                <VerticalStackLayout Spacing="12">
                    <Label Text="SMS Messages Management" FontAttributes="Bold" FontSize="16" />

                    <Button Text="Clear All SMS Messages" 
                            Command="{Binding ClearSmsMessagesCommand}"
                            BackgroundColor="Red" 
                            TextColor="White"
                            Padding="12"
                            FontAttributes="Bold" />

                    <Label Text="Deletes all imported and processed SMS messages. This cannot be undone." 
                           FontSize="Small" 
                           TextColor="Gray" />

                    <Button Text="Clear Pending Messages" 
                            Command="{Binding ClearUnprocessedMessagesCommand}"
                            BackgroundColor="Orange" 
                            TextColor="White"
                            Padding="12"
                            FontAttributes="Bold"
                            Margin="0,10,0,0" />

                    <Label Text="Deletes only unprocessed (pending) SMS messages that you haven't acted on yet." 
                           FontSize="Small" 
                           TextColor="Gray" />
                </VerticalStackLayout>
            </Border>

            <!-- Info Section -->
            <!-- Configured to use Border container with Dynamic Card Context color parameters -->
            <Border Background="{DynamicResource CardBackground}" 
                    StrokeShape="RoundRectangle 12" 
                    StrokeThickness="0" 
                    Padding="16" 
                    Margin="0">
                <VerticalStackLayout Spacing="8">
                    <Label Text="About SMS Messages" FontAttributes="Bold" FontSize="14" />

                    <Label Text="• SMS messages are imported from your device inbox" FontSize="Small" />
                    <Label Text="• Unprocessed messages await your categorization" FontSize="Small" />
                    <Label Text="• Processed messages become expense records" FontSize="Small" />
                    <Label Text="• Clearing does not delete your expense history" FontSize="Small" />
                </VerticalStackLayout>
            </Border>

            <Label Text="" />

            <Label Text="Version 1.0" 
                   FontSize="Small" 
                   TextColor="Gray"
                   HorizontalTextAlignment="Center" />

            <HorizontalStackLayout Spacing="12" VerticalOptions="Center">
                <Label Text="Dark Mode" VerticalOptions="Center" />
                <!-- Mode=TwoWay explicitly guarantees UI toggles communicate state changes cleanly down to the ViewModel -->
                <Switch IsToggled="{Binding IsDarkModeEnabled, Mode=TwoWay}" />
            </HorizontalStackLayout>

            <Label Text="{Binding StatusMessage}" TextColor="Green" IsVisible="{Binding StatusMessage, Converter={StaticResource StringNotNullOrEmptyConverter}}" />
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>