<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:viewmodels="clr-namespace:ExpenseTracker.ViewModels"
             xmlns:models="clr-namespace:ExpenseTracker.Models"
             x:Class="ExpenseTracker.Views.CategoryDetailsPage"
             x:DataType="viewmodels:CategoryDetailsViewModel"
             Title="{Binding Title}">

    <Grid RowDefinitions="Auto, *">
        <!-- Summary Header Panel -->
        <VerticalStackLayout Grid.Row="0" Padding="20" BackgroundColor="{AppThemeBinding Light=#F3F3F3, Dark=#212121}" Spacing="10">
            <Label Text="{Binding CategoryName}" FontSize="24" FontAttributes="Bold" HorizontalOptions="Center"/>

            <Border StrokeShape="RoundRectangle 8" Padding="15" BackgroundColor="{AppThemeBinding Light=#FFFFFF, Dark=#1E1E1E}">
                <VerticalStackLayout Spacing="5">
                    <Grid ColumnDefinitions="*, Auto">
                        <Label Text="Transactions" FontSize="14" TextColor="Gray"/>
                        <Label Grid.Column="1" Text="{Binding TransactionCount}" FontAttributes="Bold"/>
                    </Grid>
                    <Grid ColumnDefinitions="*, Auto">
                        <Label Text="Total Debits" FontSize="14" TextColor="Gray"/>
                        <Label Grid.Column="1" Text="{Binding TotalDebit, StringFormat='₹{0:F2}'}" TextColor="Red" FontAttributes="Bold"/>
                    </Grid>
                    <Grid ColumnDefinitions="*, Auto">
                        <Label Text="Total Credits" FontSize="14" TextColor="Gray"/>
                        <Label Grid.Column="1" Text="{Binding TotalCredit, StringFormat='₹{0:F2}'}" TextColor="Green" FontAttributes="Bold"/>
                    </Grid>
                    <BoxView HeightRequest="1" Color="LightGray" Margin="0,5"/>
                    <Grid ColumnDefinitions="*, Auto">
                        <Label Text="Net Expense" FontSize="16" FontAttributes="Bold"/>
                        <Label Grid.Column="1" Text="{Binding NetExpense, StringFormat='₹{0:F2}'}" FontSize="16" FontAttributes="Bold"/>
                    </Grid>
                </VerticalStackLayout>
            </Border>
        </VerticalStackLayout>

        <!-- Grouped Transaction Records List -->
        <CollectionView Grid.Row="1" 
                        ItemsSource="{Binding GroupedTransactions}"
                        IsGrouped="True"
                        SelectionMode="None">

            <!-- Group Sticky Headers (Dates) -->
            <CollectionView.GroupHeaderTemplate>
                <DataTemplate>
                    <Grid BackgroundColor="{AppThemeBinding Light=#EFEFEF, Dark=#2D2D2D}" Padding="15,8">
                        <Label Text="{Binding Key, StringFormat='{0:dd MMM yyyy}'}" FontAttributes="Bold" VerticalOptions="Center"/>
                    </Grid>
                </DataTemplate>
            </CollectionView.GroupHeaderTemplate>

            <!-- Child Row Entries Layout -->
            <CollectionView.ItemTemplate>
                <DataTemplate x:DataType="models:Expense">
                    <Grid Padding="15,12" ColumnDefinitions="*, Auto" RowDefinitions="Auto, Auto">
                        <Label Grid.Column="0" Grid.Row="0" Text="{Binding Merchant}" FontAttributes="Bold" FontSize="16"/>
                        <Label Grid.Column="0" Grid.Row="1" Text="{Binding PaymentMethod}" FontSize="12" TextColor="Gray" Margin="0,2,0,0"/>

                        <Label Grid.Column="1" Grid.Row="0" Grid.RowSpan="2" 
                               Text="{Binding Amount, StringFormat='₹{0:F2}'}" 
                               FontAttributes="Bold" 
                               FontSize="16" 
                               VerticalOptions="Center"
                               HorizontalOptions="End"/>
                    </Grid>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>
    </Grid>
</ContentPage>